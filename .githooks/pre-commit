#!/bin/sh
# Pre-commit gate — refuse the commit unless the project builds and tests pass.
#
# Why this exists: see CLAUDE.md "Working Agreement". Commit messages and verbal
# claims are not enforcement; this hook is. It runs the same checks a commit
# message would assert ("build clean", "tests pass") and blocks the commit if
# either fails — so a silently-failed edit can never land on a branch.
#
# Escape hatch: `git commit --no-verify` skips this. Per project policy it is
# only used when explicitly requested (e.g. a genuine docs-only commit).

echo "pre-commit: running build + tests (this takes a few seconds)..."

npm run build
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ pre-commit BLOCKED: 'npm run build' failed."
  echo "  Fix the build (tsc/vite) before committing, or re-run with --no-verify if intentional."
  exit 1
fi

npm test
if [ $? -ne 0 ]; then
  echo ""
  echo "✗ pre-commit BLOCKED: 'npm test' failed."
  echo "  Fix failing tests before committing, or re-run with --no-verify if intentional."
  exit 1
fi

echo "✓ pre-commit: build + tests passed."
exit 0
